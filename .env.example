# ── Backend (server/) ──────────────────────────────────────────────────────
PORT=4000
DB_PATH=./server/data.sqlite

# Azure AD / Entra ID - validación del login de Office (mismo tenant y mismo
# App Registration que usa el frontend si sigues la opción de "un solo app").
AZURE_TENANT_ID=
AZURE_API_CLIENT_ID=

# Azure AD - app confidencial "solo aplicación" (App-only) para escribir en
# SharePoint vía Microsoft Graph. Es un App Registration DISTINTO, con un
# Client Secret y permiso de aplicación Sites.Selected (o Sites.ReadWrite.All).
AZURE_GRAPH_CLIENT_ID=
AZURE_GRAPH_CLIENT_SECRET=

# SharePoint: id del sitio y de las listas (las listas las crea
# server/scripts/provisionSharePoint.js la primera vez; copia aquí lo que imprima).
SHAREPOINT_SITE_ID=
SHAREPOINT_LIST_VIAJES_ID=
SHAREPOINT_LIST_TRAYECTOS_ID=

# ── Frontend (Vite) ─────────────────────────────────────────────────────────
# Azure AD / Entra ID - App Registration tipo SPA con el que los viajeros
# inician sesión con su cuenta de Office.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
# Scope de la API expuesta por el mismo App Registration (Expose an API):
# api://<AZURE_API_CLIENT_ID>/access_as_user
VITE_AZURE_API_SCOPE=

# EmailJS: https://www.emailjs.com
# Crea un servicio + una plantilla con las variables {{to_fijo}}, {{to_variable}}, {{subject}}, {{message}}
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Solo si el frontend y el backend NO se sirven desde el mismo dominio en producción:
# VITE_API_URL=https://tu-backend.example.com/api
